# Copy this file to .env.docker-aws-tools to let the Docker lifecycle scripts
# mount your local AWS configuration into the backend container.
#
# This is intentionally opt-in because it exposes host cloud credentials to the
# container. Keep the mounted credentials read-only and prefer a least-privilege
# AWS profile for demos and screenshots.

LOCAL_GENAI_LAB_ENABLE_AWS_TOOLS=true

# Optional. Defaults to $HOME/.aws when omitted by the wrapper scripts.
# Use an absolute path if your AWS configuration lives somewhere else.
# LOCAL_GENAI_LAB_AWS_DIR=/absolute/path/to/.aws

AWS_PROFILE=default
AWS_REGION=us-east-2
AWS_DEFAULT_REGION=us-east-2
