# Copy this file to .env and fill in only the providers you want available in the
# running backend process. Use scripts/run-backend.sh to start the backend.

# Default backend provider used at startup.
APP_MODEL_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3:8b

# Bedrock
BEDROCK_REGION=us-east-2
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Hugging Face
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_API_TOKEN=hf_xxx
HUGGINGFACE_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_MODELS=meta-llama/Llama-3.1-8B-Instruct,Qwen/Qwen2.5-72B-Instruct,mistralai/Mistral-7B-Instruct-v0.3

# Shared backend options
MCP_ENABLED=true
