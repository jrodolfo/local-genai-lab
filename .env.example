# Copy this file to .env and fill in only the providers you want available in the
# running backend process. Use ./start.sh to start the app.

# Optional instance label shown in the UI header.
APP_INSTANCE_NAME=

# Default backend provider used at startup.
APP_MODEL_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Docker backend uses host.docker.internal to reach Ollama on the host.
# Override only if your Docker host exposes Ollama somewhere else.
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3:8b

# Bedrock
BEDROCK_REGION=us-east-2
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Hugging Face
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_API_TOKEN=hf_xxx
HUGGINGFACE_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_MODELS=meta-llama/Llama-3.1-8B-Instruct,Qwen/Qwen2.5-72B-Instruct,mistralai/Mistral-7B-Instruct-v0.3

# Shared backend options
MCP_ENABLED=true

# Experimental RAG
RAG_ENABLED=true
RAG_RETRIEVAL_MODE=lexical
RAG_VECTOR_STORE=in-memory
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=local_genai_lab_docs
RAG_EXCLUDED_SOURCE_PATHS=rag-evaluation-guide.md,rag-retrieval-evaluation-template.md
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=nomic-embed-text
