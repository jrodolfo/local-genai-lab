[
  {
    "name": "planner routes aws audit request",
    "mode": "hybrid",
    "message": "please audit my aws account in us-east-2 with sts",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"aws_region_audit\",\"arguments\":{\"region\":\"us-east-2\",\"services\":[\"sts\"]},\"missingFields\":[],\"reason\":\"The user explicitly asked for an AWS audit.\"}",
    "expectedType": "AWS_REGION_AUDIT",
    "expectedUseTool": true,
    "expectedClarification": false,
    "expectedFallbackUsed": false,
    "expectedRegion": "us-east-2",
    "expectedServices": ["sts"]
  },
  {
    "name": "planner asks for bucket clarification",
    "mode": "hybrid",
    "message": "check s3 cloudwatch metrics for the last 7 days",
    "plannerResponse": "{\"action\":\"clarification_needed\",\"toolName\":\"s3_cloudwatch_report\",\"arguments\":{\"days\":7},\"missingFields\":[\"bucket\"],\"reason\":\"Bucket metrics request is missing the bucket name.\"}",
    "expectedType": "S3_CLOUDWATCH_REPORT",
    "expectedUseTool": false,
    "expectedClarification": true,
    "expectedFallbackUsed": false
  },
  {
    "name": "malformed planner output falls back to rules",
    "mode": "hybrid",
    "message": "run aws audit for us-east-2 sts",
    "plannerResponse": "not valid json",
    "expectedType": "AWS_REGION_AUDIT",
    "expectedUseTool": true,
    "expectedClarification": false,
    "expectedFallbackUsed": true,
    "expectedRegion": "us-east-2",
    "expectedServices": ["sts"]
  },
  {
    "name": "planner keeps normal chat as none",
    "mode": "hybrid",
    "message": "explain recursion using a simple example",
    "plannerResponse": "{\"action\":\"none\",\"toolName\":null,\"arguments\":{},\"missingFields\":[],\"reason\":\"No tool is needed.\"}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "live miss plain recursion question must not become report lookup",
    "mode": "hybrid",
    "message": "explain recursion using a simple example",
    "plannerResponse": "{\n  \"action\": \"use_tool\",\n  \"toolName\": \"list_recent_reports\",\n  \"arguments\": {},\n  \"missingFields\": [],\n  \"reason\": \"Supported tool for report listing\"\n}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "pending follow-up resolves missing bucket",
    "mode": "hybrid",
    "message": "jrodolfo.net",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"s3_cloudwatch_report\",\"arguments\":{\"bucket\":\"jrodolfo.net\",\"days\":7},\"missingFields\":[],\"reason\":\"The follow-up provides the missing bucket.\"}",
    "pendingTool": {
      "type": "S3_CLOUDWATCH_REPORT",
      "reason": "s3 cloudwatch metrics request",
      "days": 7,
      "missingFields": ["bucket"]
    },
    "expectedType": "S3_CLOUDWATCH_REPORT",
    "expectedUseTool": true,
    "expectedClarification": false,
    "expectedFallbackUsed": false,
    "expectedBucket": "jrodolfo.net"
  },
  {
    "name": "planner markdown json still parses",
    "mode": "hybrid",
    "message": "show my recent audit reports",
    "plannerResponse": "```json\n{\"action\":\"use_tool\",\"toolName\":\"list_recent_reports\",\"arguments\":{\"reportType\":\"audit\"},\"missingFields\":[],\"reason\":\"The user wants recent audit reports.\"}\n```",
    "expectedType": "LIST_REPORTS",
    "expectedUseTool": true,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "planner use tool without bucket becomes clarification",
    "mode": "hybrid",
    "message": "show cloudwatch metrics for my bucket",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"s3_cloudwatch_report\",\"arguments\":{\"days\":14},\"missingFields\":[],\"reason\":\"The user wants an S3 metrics report.\"}",
    "expectedType": "S3_CLOUDWATCH_REPORT",
    "expectedUseTool": false,
    "expectedClarification": true,
    "expectedFallbackUsed": false
  },
  {
    "name": "planner ambiguous latest report becomes clarification",
    "mode": "hybrid",
    "message": "read the latest report",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"read_report_summary\",\"arguments\":{\"reportType\":\"all\"},\"missingFields\":[],\"reason\":\"The user wants the most recent report.\"}",
    "expectedType": "READ_LATEST_REPORT",
    "expectedUseTool": false,
    "expectedClarification": true,
    "expectedFallbackUsed": false
  },
  {
    "name": "unsupported tool falls back to safe none",
    "mode": "hybrid",
    "message": "what is the weather in halifax today",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"weather_lookup\",\"arguments\":{\"location\":\"Halifax\"},\"missingFields\":[],\"reason\":\"The user wants weather.\"}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "bucket discussion without metrics must stay plain chat",
    "mode": "hybrid",
    "message": "how do buckets work in aws s3?",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"s3_cloudwatch_report\",\"arguments\":{\"bucket\":\"example-bucket\"},\"missingFields\":[],\"reason\":\"The user is asking about s3 buckets.\"}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "aws concept question must not become audit",
    "mode": "hybrid",
    "message": "explain sts in aws",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"aws_region_audit\",\"arguments\":{\"region\":\"us-east-2\",\"services\":[\"sts\"]},\"missingFields\":[],\"reason\":\"The user mentioned sts in aws.\"}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  },
  {
    "name": "report quality discussion must stay plain chat",
    "mode": "hybrid",
    "message": "what makes a good engineering report?",
    "plannerResponse": "{\"action\":\"use_tool\",\"toolName\":\"read_report_summary\",\"arguments\":{\"reportType\":\"audit\"},\"missingFields\":[],\"reason\":\"The user mentioned report.\"}",
    "expectedType": "NONE",
    "expectedUseTool": false,
    "expectedClarification": false,
    "expectedFallbackUsed": false
  }
]
